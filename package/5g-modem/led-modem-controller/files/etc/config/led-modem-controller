config led_controller 'settings'
	option enabled '1'
	option fallback_devices '/dev/ttyUSB1 /dev/ttyUSB2 /dev/ttyUSB3'
	option update_interval '60'
	option timeout '15'
	option max_errors '3'
	option cache_timeout '180'
	option debug '0'

config led_mapping 'leds'
	option led_4g_blue '/sys/class/leds/wt:4g:blue'
	option led_4g_green '/sys/class/leds/wt:4g:green'
	option led_4g_yellow '/sys/class/leds/wt:4g:yellow'
	option led_5g_blue '/sys/class/leds/wt:5g:blue'
	option led_5g_yellow '/sys/class/leds/wt:5g:yellow'

config signal_thresholds 'signal'
	option excellent_rsrp '-80'
	option good_rsrp '-89'
	option weak_rsrp '-999'